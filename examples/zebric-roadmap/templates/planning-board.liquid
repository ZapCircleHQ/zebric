<style>
  .kb{--ink:#1c1922;--muted:#706a77;--line:#ddd9e2;--bg:#f1eff3;color:var(--ink);background:var(--bg);margin:-2rem 0;padding-bottom:40px;min-width:1050px;font:14px/1.45 Inter,ui-sans-serif,system-ui,sans-serif}.kb *{box-sizing:border-box}.kb-top{height:64px;background:#fff;border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 26px}.kb-brand{font-size:17px;font-weight:800;text-decoration:none}.kb-nav{display:flex;gap:20px;align-items:center}.kb-nav a{font-size:12px;color:var(--muted);text-decoration:none}.kb-nav .kb-new{background:var(--ink);color:#fff;padding:8px 12px;border-radius:6px}.kb-page{padding:28px 26px}.kb-head{margin-bottom:22px}.kb-head h1{font-size:29px;letter-spacing:-.04em;margin:0}.kb-head p{color:var(--muted);margin:3px 0 0}.kb-board{display:grid;grid-template-columns:repeat(4,minmax(240px,1fr));gap:13px;align-items:start}.kb-column{background:#e6e3e9;border-radius:10px;padding:11px;min-height:520px}.kb-column>header{display:flex;justify-content:space-between;padding:4px 4px 12px}.kb-column h2{font-size:12px;margin:0}.kb-column header span{font-size:10px;color:var(--muted)}.kb-cards{display:grid;gap:8px}.kb-card{background:#fff;border:1px solid var(--line);border-radius:8px;padding:14px}.kb-meta{display:flex;justify-content:space-between;color:#7059c3;font-size:9px;text-transform:uppercase;letter-spacing:.07em;font-weight:800}.kb-card h3{font-size:14px;line-height:1.25;margin:13px 0 6px}.kb-card h3 a{text-decoration:none}.kb-card p{font-size:11px;color:var(--muted);margin:0}.kb-tags{display:flex;gap:5px;flex-wrap:wrap;margin:12px 0}.kb-tags span{font-size:9px;border:1px solid var(--line);border-radius:4px;padding:2px 5px;color:#655f6b}.kb-owner{display:flex;justify-content:space-between;border-top:1px solid #eeeaf0;padding-top:9px;color:var(--muted);font-size:10px}.kb-owner a{color:var(--ink);font-weight:700;text-decoration:none}
</style>
<div class="kb">
  <nav class="kb-top"><a class="kb-brand" href="/">Zebric roadmap</a><div class="kb-nav"><a href="/">Public view</a><a href="/themes">Themes</a><a href="/updates">Updates</a><a class="kb-new" href="/items/new">+ Add item</a></div></nav>
  <main class="kb-page"><header class="kb-head"><h1>Planning board</h1><p>{{ data.items | size }} items across the delivery pipeline.</p></header><div class="kb-board">
    <section class="kb-column"><header><div><h2>Candidate</h2><span>Ideas under consideration</span></div></header><div class="kb-cards">{% for item in data.items %}{% if item.status == "candidate" %}<article class="kb-card"><div class="kb-meta"><span>{{ item.theme.title }}</span><span>{{ item.visibility }}</span></div><h3><a href="/items/{{ item.id }}">{{ item.title }}</a></h3><p>{{ item.summary }}</p><div class="kb-tags"><span>{{ item.horizon }}</span><span>{{ item.confidence }}</span><span>{{ item.target }}</span></div><div class="kb-owner"><span>{{ item.owner }}</span><a href="/items/{{ item.id }}">Open →</a></div></article>{% endif %}{% endfor %}</div></section>
    <section class="kb-column"><header><div><h2>Planned</h2><span>Sequenced for delivery</span></div></header><div class="kb-cards">{% for item in data.items %}{% if item.status == "planned" %}<article class="kb-card"><div class="kb-meta"><span>{{ item.theme.title }}</span><span>{{ item.visibility }}</span></div><h3><a href="/items/{{ item.id }}">{{ item.title }}</a></h3><p>{{ item.summary }}</p><div class="kb-tags"><span>{{ item.horizon }}</span><span>{{ item.confidence }}</span><span>{{ item.target }}</span></div><div class="kb-owner"><span>{{ item.owner }}</span><a href="/items/{{ item.id }}">Open →</a></div></article>{% endif %}{% endfor %}</div></section>
    <section class="kb-column"><header><div><h2>In progress</h2><span>Active work</span></div></header><div class="kb-cards">{% for item in data.items %}{% if item.status == "in_progress" %}<article class="kb-card"><div class="kb-meta"><span>{{ item.theme.title }}</span><span>{{ item.visibility }}</span></div><h3><a href="/items/{{ item.id }}">{{ item.title }}</a></h3><p>{{ item.summary }}</p><div class="kb-tags"><span>{{ item.horizon }}</span><span>{{ item.confidence }}</span><span>{{ item.target }}</span></div><div class="kb-owner"><span>{{ item.owner }}</span><a href="/items/{{ item.id }}">Open →</a></div></article>{% endif %}{% endfor %}</div></section>
    <section class="kb-column"><header><div><h2>Shipped</h2><span>Released outcomes</span></div></header><div class="kb-cards">{% for item in data.items %}{% if item.status == "shipped" %}<article class="kb-card"><div class="kb-meta"><span>{{ item.theme.title }}</span><span>{{ item.visibility }}</span></div><h3><a href="/items/{{ item.id }}">{{ item.title }}</a></h3><p>{{ item.summary }}</p><div class="kb-tags"><span>{{ item.horizon }}</span><span>{{ item.confidence }}</span><span>{{ item.target }}</span></div><div class="kb-owner"><span>{{ item.owner }}</span><a href="/items/{{ item.id }}">Open →</a></div></article>{% endif %}{% endfor %}</div></section>
  </div></main>
</div>
