{
  "name": "@zebric/runtime-simulator",
  "version": "0.0.0",
  "description": "Browser-only Zebric simulator runtime",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --coverage=false",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "@zebric/runtime-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
