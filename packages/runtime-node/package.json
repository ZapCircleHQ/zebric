{
  "name": "@zebric/runtime-node",
  "version": "0.2.3",
  "description": "Zebric Runtime Node.js Adapter - Hono, SQLite, PostgreSQL, S3, Redis",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Jeff Linwood",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZapCircleHQ/zebric.git",
    "directory": "packages/runtime-node"
  },
  "keywords": [
    "zebric",
    "runtime",
    "node",
    "fastify",
    "adapter"
  ],
  "homepage": "https://github.com/ZapCircleHQ/zebric#readme",
  "bugs": {
    "url": "https://github.com/ZapCircleHQ/zebric/issues"
  },
  "scripts": {
    "pretest": "pnpm --filter @zebric/runtime-core build && pnpm --filter @zebric/runtime-hono build && pnpm --filter @zebric/notifications build && pnpm --filter @zebric/observability build",
    "pretest:browser": "pnpm --filter @zebric/runtime-core build && pnpm --filter @zebric/runtime-hono build && pnpm --filter @zebric/notifications build && pnpm --filter @zebric/observability build",
    "pretest:coverage": "pnpm --filter @zebric/runtime-core build && pnpm --filter @zebric/runtime-hono build && pnpm --filter @zebric/notifications build && pnpm --filter @zebric/observability build",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:agent-browser": "RUN_AGENT_BROWSER_E2E=1 vitest run tests/e2e/agent-browser.e2e.test.ts",
    "test:browser": "playwright test --config=playwright.config.ts",
    "test:browser:accessibility": "playwright test --config=playwright.config.ts --grep @accessibility",
    "test:browser:journeys": "playwright test --config=playwright.config.ts --grep @journey",
    "test:browser:performance": "playwright test --config=playwright.config.ts --grep @performance",
    "test:browser:rendering": "playwright test --config=playwright.config.ts --grep @rendering",
    "test:browser:install": "playwright install chromium",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "@zebric/notifications": "workspace:*",
    "@zebric/observability": "workspace:*",
    "@zebric/runtime-core": "workspace:*",
    "@zebric/runtime-hono": "workspace:*",
    "better-auth": "^1.3.26",
    "better-sqlite3": "^9.6.0",
    "bullmq": "^5.4.2",
    "chokidar": "^3.6.0",
    "drizzle-kit": "^0.20.14",
    "drizzle-orm": "^0.30.8",
    "hono": "^4.9.9",
    "ioredis": "^5.3.2",
    "postgres": "^3.4.4",
    "ulid": "^3.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
