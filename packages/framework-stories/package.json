{
  "name": "@zebric/framework-stories",
  "version": "0.2.2",
  "description": "User stories and integration tests for the Zebric framework",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "stories": "vitest run --runInBand",
    "pretest": "pnpm --filter @zebric/runtime-core build",
    "prestories": "pnpm --filter @zebric/runtime-core build"
  },
  "dependencies": {
    "@zebric/cli": "workspace:*",
    "@zebric/runtime-core": "workspace:*",
    "@zebric/runtime-node": "workspace:*",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
