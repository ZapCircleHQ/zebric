{
  "name": "@zebric/react-simulator",
  "version": "0.0.0",
  "description": "React component wrapper for the Zebric browser simulator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/styles.css dist/styles.css",
    "dev": "tsc --watch",
    "test": "vitest run --coverage=false",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "@zebric/runtime-core": "workspace:*",
    "@zebric/runtime-simulator": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^15.11.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
