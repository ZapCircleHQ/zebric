# Development Dockerfile for Zebric
# This Dockerfile is optimized for local development with hot reload

FROM node:22-alpine AS base

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Set working directory
WORKDIR /app

# Install curl for healthchecks
RUN apk add --no-cache curl

# Development stage
FROM base AS development

# Copy full source (workspace package.json files must all be present for
# pnpm install, and packages/runtime-core's postinstall needs its own
# source); overridden by the bind mount in docker-compose.dev.yml anyway
COPY . .

# Install all dependencies (including devDependencies)
RUN pnpm install --frozen-lockfile

# Expose application and metrics ports
EXPOSE 3000 9090

# Default command (can be overridden in docker-compose)
CMD ["pnpm", "dev"]
